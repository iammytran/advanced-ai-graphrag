    <edge source="C&#416; QUAN C&#211; TH&#7848;M QUY&#7872;N TI&#7870;N H&#192;NH T&#7888; T&#7908;NG" target="C&#193; NH&#194;N, T&#7892; CH&#7912;C">
      <data key="d0">Ph&#7843;i chuy&#7875;n k&#7871;t qu&#7843; ph&#7909;c h&#7891;i, t&#236;m ki&#7871;m, gi&#225;m &#273;&#7883;nh sang d&#7841;ng c&#243; th&#7875; &#273;&#7885;c, nghe ho&#7863;c nh&#236;n &#273;&#432;&#7907;c</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="C&#416; QUAN C&#211; TH&#7848;M QUY&#7872;N TI&#7870;N H&#192;NH T&#7888; T&#7908;NG" target="&#272;I&#7872;U 222 (LU&#7852;T H&#204;NH S&#7920; 2015)">
      <data key="d0">Ph&#7843;i xem x&#233;t, ra v&#259;n b&#7843;n y&#234;u c&#7847;u &#273;&#7883;nh gi&#225; t&#224;i s&#7843;n khi nh&#7853;n &#273;&#432;&#7907;c &#273;&#7873; ngh&#7883; c&#7911;a b&#7883; can, b&#7883; c&#225;o, b&#7883; h&#7841;i, ng&#432;&#7901;i tham gia t&#7889; t&#7909;ng kh&#225;c</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="C&#416; QUAN C&#211; TH&#7848;M QUY&#7872;N TI&#7870;N H&#192;NH T&#7888; T&#7908;NG" target="B&#7882; CAN, B&#7882; C&#193;O, B&#7882; H&#7840;I, NG&#431;&#7900;I THAM GIA T&#7888; T&#7908;NG KH&#193;C">
      <data key="d0">Ph&#7843;i th&#244;ng b&#225;o k&#7871;t lu&#7853;n &#273;&#7883;nh gi&#225; t&#224;i s&#7843;n cho b&#7883; can, b&#7883; c&#225;o, b&#7883; h&#7841;i, ng&#432;&#7901;i tham gia t&#7889; t&#7909;ng kh&#225;c c&#243; li&#234;n quan</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 92 (B&#7896; LU&#7852;T H&#204;NH S&#7920; 2015)" target="KHO&#7842;N 60 &#272;I&#7872;U 1 LU&#7852;T S&#7888; 99/2025/QH15">
      <data key="d0">Thay th&#7871; c&#7909;m t&#7915; "ch&#237;nh quy&#7873;n &#273;&#7883;a ph&#432;&#417;ng" b&#7857;ng c&#7909;m t&#7915; "&#7910;y ban nh&#226;n d&#226;n"</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 92 (B&#7896; LU&#7852;T H&#204;NH S&#7920; 2015)" target="B&#7882; H&#7842;I">
      <data key="d0">Kh&#244;ng &#273;&#432;&#7907;c d&#249;ng l&#224;m ch&#7913;ng c&#7913; nh&#7919;ng t&#236;nh ti&#7871;t do b&#7883; h&#7841;i tr&#236;nh b&#224;y n&#7871;u h&#7885; kh&#244;ng th&#7875; n&#243;i r&#245; v&#236; sao bi&#7871;t &#273;&#432;&#7907;c t&#236;nh ti&#7871;t &#273;&#243;.</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="B&#7882; H&#7842;I" target="&#272;I&#7872;U 136 (BO LU&#7852;T H&#204;NH S&#7920; 2015)">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; tr&#225;ch nhi&#7879;m c&#7911;a b&#7883; h&#7841;i ph&#7843;i tr&#7843; &#225;n ph&#237;</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;i&#7873;u 95 (bo_luat_to_tung_hinh_su_2015.pdf)" target="NG&#431;&#7900;I B&#7882; GI&#7918; TRONG TR&#431;&#7900;NG H&#7906;P KH&#7858;N C&#7844;P, NG&#431;&#7900;I B&#7882; T&#7888; GI&#193;C, NG&#431;&#7900;I B&#7882; KI&#7870;N NGH&#7882; KH&#7902;I T&#7888;, NG&#431;&#7900;I PH&#7840;M T&#7896;I T&#7920; TH&#218;, &#272;&#7846;U TH&#218;, NG&#431;&#7900;I B&#7882; B&#7854;T, B&#7882; T&#7840;M GI&#7918;">
