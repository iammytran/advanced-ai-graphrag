    <edge source="QUY &#272;&#7882;NH V&#7872; NG&#431;&#7900;I LAO &#272;&#7896;NG" target="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; ng&#432;&#7901;i lao &#273;&#7897;ng l&#224; &#273;&#7889;i t&#432;&#7907;ng &#273;&#432;&#7907;c quy &#273;&#7883;nh trong quy &#273;&#7883;nh v&#7873; ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng</data>
      <data key="d1">8.0</data>
    </edge>
