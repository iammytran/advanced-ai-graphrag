    <edge source="&#272;I&#7872;U 202 (B&#7896; LU&#7852;T LAO &#272;&#7896;NG 2019)" target="&#7910;Y BAN NH&#194;N D&#194;N C&#7844;P HUY&#7878;N">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; ngh&#297;a v&#7909; c&#7911;a &#7910;y ban nh&#226;n d&#226;n c&#7845;p huy&#7879;n khi ng&#432;&#7901;i lao &#273;&#7897;ng t&#7893; ch&#7913;c v&#224; l&#227;nh &#273;&#7841;o &#273;&#236;nh c&#244;ng</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 202 (B&#7896; LU&#7852;T LAO &#272;&#7896;NG 2019)" target="C&#416; QUAN CHUY&#202;N M&#212;N V&#7872; LAO &#272;&#7896;NG THU&#7920;C &#7910;Y BAN NH&#194;N D&#194;N C&#7844;P T&#7882;NH">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; ngh&#297;a v&#7909; c&#7911;a c&#417; quan chuy&#234;n m&#244;n v&#7873; lao &#273;&#7897;ng thu&#7897;c &#7910;y ban nh&#226;n d&#226;n c&#7845;p t&#7881;nh khi ng&#432;&#7901;i lao &#273;&#7897;ng t&#7893; ch&#7913;c v&#224; l&#227;nh &#273;&#7841;o &#273;&#236;nh c&#244;ng</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 204 (BO LU&#7852;T LAO &#272;&#7896;NG 2019)" target="&#272;I&#7872;U 199 (BO LU&#7852;T LAO &#272;&#7896;NG 2019)">
      <data key="d0">Kh&#244;ng thu&#7897;c tr&#432;&#7901;ng h&#7907;p &#273;&#432;&#7907;c &#273;&#236;nh c&#244;ng quy &#273;&#7883;nh t&#7841;i &#272;i&#7873;u 199 d&#7851;n &#273;&#7871;n vi ph&#7841;m quy &#273;&#7883;nh t&#7841;i &#272;i&#7873;u 204</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 204 (BO LU&#7852;T LAO &#272;&#7896;NG 2019)" target="QUY &#272;&#7882;NH V&#7872; TR&#204;NH T&#7920;, TH&#7910; T&#7908;C TI&#7870;N H&#192;NH &#272;&#204;NH C&#212;NG">
      <data key="d0">Vi ph&#7841;m c&#225;c quy &#273;&#7883;nh v&#7873; tr&#236;nh t&#7921;, th&#7911; t&#7909;c ti&#7871;n h&#224;nh &#273;&#236;nh c&#244;ng d&#7851;n &#273;&#7871;n vi ph&#7841;m quy &#273;&#7883;nh t&#7841;i &#272;i&#7873;u 204</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 204 (BO LU&#7852;T LAO &#272;&#7896;NG 2019)" target="C&#416; QUAN, T&#7892; CH&#7912;C, C&#193; NH&#194;N C&#211; TH&#7874; QUY&#7872;N GI&#7842;I QUY&#7870;T">
      <data key="d0">Khi tranh ch&#7845;p lao &#273;&#7897;ng t&#7853;p th&#7875; &#273;ang &#273;&#432;&#7907;c c&#417; quan, t&#7893; ch&#7913;c, c&#225; nh&#226;n c&#243; th&#7849;m quy&#7873;n gi&#7843;i quy&#7871;t theo quy &#273;&#7883;nh c&#7911;a B&#7897; lu&#7853;t n&#224;y d&#7851;n &#273;&#7871;n vi ph&#7841;m quy &#273;&#7883;nh t&#7841;i &#272;i&#7873;u 204</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 204 (BO LU&#7852;T LAO &#272;&#7896;NG 2019)" target="TR&#431;&#7900;NG H&#7906;P KH&#212;NG &#272;&#431;&#7906;C &#272;&#204;NH C&#212;NG">
      <data key="d0">Vi ph&#7841;m quy &#273;&#7883;nh v&#7873; tr&#432;&#7901;ng h&#7907;p kh&#244;ng &#273;&#432;&#7907;c &#273;&#236;nh c&#244;ng d&#7851;n &#273;&#7871;n vi ph&#7841;m quy &#273;&#7883;nh t&#7841;i &#272;i&#7873;u 204</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 204 (BO LU&#7852;T LAO &#272;&#7896;NG 2019)" target="QUY&#7870;T &#272;&#7882;NH HO&#195;N HO&#7862;C NG&#7898;NG &#272;&#204;NH C&#212;NG">
      <data key="d0">Khi &#273;&#227; c&#243; quy&#7871;t &#273;&#7883;nh ho&#227;n ho&#7863;c ng&#7915;ng &#273;&#236;nh c&#244;ng c&#7911;a c&#417; quan c&#243; th&#7849;m quy&#7873;n theo quy &#273;&#7883;nh t&#7841;i &#272;i&#7873;u 210 d&#7851;n &#273;&#7871;n vi ph&#7841;m quy &#273;&#7883;nh t&#7841;i &#272;i&#7873;u 204</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="CH&#7910; T&#7882;CH &#7910;Y BAN NH&#194;N D&#194;N C&#7844;P HUY&#7878;N" target="&#272;I&#7872;U 211 (B&#7896; LU&#7852;T LAO &#272;&#7896;NG 2019)">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; quy&#7873;n, tr&#225;ch nhi&#7879;m c&#7911;a Ch&#7911; t&#7883;ch &#7910;y ban nh&#226;n d&#226;n c&#7845;p huy&#7879;n</data>
      <data key="d1">9.0</data>
    </edge>
