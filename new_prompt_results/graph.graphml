      <data key="d0">Ph&#225;p l&#7879;nh quy &#273;&#7883;nh h&#224;nh vi c&#432;&#7905;ng b&#7913;c b&#225;n d&#226;m l&#224; h&#224;nh vi d&#249;ng v&#361; l&#7921;c, &#273;e do&#7841; d&#249;ng v&#361; l&#7921;c ho&#7863;c d&#249;ng th&#7911; &#273;o&#7841;n bu&#7897;c ng&#432;&#7901;i kh&#225;c ph&#7843;i th&#7921;c hi&#7879;n vi&#7879;c b&#225;n d&#226;m</data>
      <data key="d1">9.0</data>
