      <data key="d0">Quy &#273;&#7883;nh v&#7873; t&#7893; ch&#7913;c &#273;&#7841;i di&#7879;n ng&#432;&#7901;i lao &#273;&#7897;ng t&#7841;i c&#417; s&#7903; l&#224; &#273;&#7889;i t&#432;&#7907;ng &#273;&#432;&#7907;c quy &#273;&#7883;nh trong quy &#273;&#7883;nh v&#7873; ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="&#272;I&#7872;U 6 (BO LU&#7852;T H&#204;NH S&#7920; 2015)">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; quy&#7873;n v&#224; ngh&#297;a v&#7909; c&#7911;a ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng c&#243; hi&#7879;u l&#7921;c &#273;&#7889;i v&#7899;i ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="NG&#431;&#7900;I LAO &#272;&#7896;NG">
      <data key="d0">C&#243; th&#7875; c&#243; th&#7887;a thu&#7853;n kh&#225;c v&#7873; vi&#7879;c tr&#7843; l&#432;&#417;ng trong tr&#432;&#7901;ng h&#7907;p ng&#432;&#7901;i lao &#273;&#7897;ng ngh&#7881; vi&#7879;c h&#432;&#7903;ng ch&#7871; &#273;&#7897; b&#7843;o hi&#7875;m x&#227; h&#7897;i</data>
      <data key="d1">7.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="45 NG&#192;Y">
      <data key="d0">B&#225;o tr&#432;&#7899;c cho ng&#432;&#7901;i lao &#273;&#7897;ng &#237;t nh&#7845;t 45 ng&#224;y</data>
      <data key="d1">9.0</data>
    </edge>
