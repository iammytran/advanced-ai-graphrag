    <edge source="C&#416; QUAN &#272;I&#7872;U TRA" target="QUY&#7870;T &#272;&#7882;NH &#193;P D&#7908;NG TH&#7910; T&#7908;C R&#218;T G&#7884;N">
      <data key="d0">Ph&#7843;i ra quy&#7871;t &#273;&#7883;nh &#225;p d&#7909;ng th&#7911; t&#7909;c r&#250;t g&#7885;n trong th&#7901;i h&#7841;n 24 gi&#7901;</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="C&#416; QUAN &#272;I&#7872;U TRA" target="&#272;I&#7872;U 483 (LU&#7852;T H&#204;NH S&#7920; 2015)">
      <data key="d0">Vi&#7879;n ki&#7875;m s&#225;t y&#234;u c&#7847;u C&#417; quan &#273;i&#7873;u tra t&#7921; ki&#7875;m tra vi&#7879;c gi&#7843;i quy&#7871;t khi&#7871;u n&#7841;i, t&#7889; c&#225;o</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="C&#416; QUAN &#272;I&#7872;U TRA" target="H&#7890; S&#416; B&#7842;O V&#7878;">
      <data key="d0">Ph&#7843;i l&#7853;p h&#7891; s&#417; b&#7843;o v&#7879; tr&#432;&#7899;c khi &#225;p d&#7909;ng bi&#7879;n ph&#225;p b&#7843;o v&#7879;</data>
      <data key="d1">9.0</data>
    </edge>
