    <edge source="&#272;i&#7873;u 12 (bo_luat_lao_dong_2019.docx)" target="CH&#205;NH PH&#7910;">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; vi&#7879;c quy &#273;&#7883;nh chi ti&#7871;t &#272;i&#7873;u n&#224;y</data>
      <data key="d1">9.0</data>
