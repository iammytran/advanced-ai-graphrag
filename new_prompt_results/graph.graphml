      <data key="d0">Ph&#225;p nh&#226;n ph&#7843;i c&#243; c&#417; c&#7845;u t&#7893; ch&#7913;c ph&#249; h&#7907;p v&#7899;i quy &#273;&#7883;nh c&#7911;a ph&#225;p lu&#7853;t</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 77 (B&#7896; LU&#7852;T H&#204;NH S&#7920; 2015)" target="&#272;I&#7872;U KI&#7878;N H&#7906;P NH&#7844;T, S&#193;P NH&#7852;P, CHIA, T&#193;CH, CHUY&#7874;N &#272;&#7892;I H&#204;NH TH&#7874;, GI&#7842;I TH&#7874; PH&#193;P NH&#194;N">
      <data key="d0">Ph&#225;p nh&#226;n ph&#7843;i tu&#226;n th&#7911; c&#225;c quy &#273;&#7883;nh v&#7873; h&#7907;p nh&#7845;t, s&#225;p nh&#7853;p, chia, t&#225;ch, chuy&#7875;n &#273;&#7893;i h&#236;nh th&#7913;c, gi&#7843;i th&#7875;</data>
      <data key="d1">9.0</data>
    </edge>
