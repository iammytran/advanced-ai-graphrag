      <data key="d0">Ph&#7843;i c&#243; trong h&#7891; s&#417; b&#7843;o v&#7879;</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 136 (BO LU&#7852;T H&#204;NH S&#7920; 2015)" target="TR&#431;&#7900;NG PH&#7842;I TR&#7842; &#193;N PH&#205;">
      <data key="d0">Vi ph&#7841;m quy &#273;&#7883;nh t&#7841;i &#272;i&#7873;u 136 d&#7851;n &#273;&#7871;n tr&#225;ch nhi&#7879;m ph&#7843;i tr&#7843; &#225;n ph&#237;</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 136 (BO LU&#7852;T H&#204;NH S&#7920; 2015)" target="TRUNG T&#194;M TR&#7906; GI&#218;P PH&#193;P LU&#7852;T NH&#192; N&#431;&#7898;C">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; tr&#225;ch nhi&#7879;m chi tr&#7843; chi ph&#237; t&#7889; t&#7909;ng, l&#7879; ph&#237;</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 136 (BO LU&#7852;T H&#204;NH S&#7920; 2015)" target="&#193;N PH&#205;">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; &#225;n ph&#237; do ng&#432;&#7901;i b&#7883; k&#7871;t &#225;n ho&#7863;c Nh&#224; n&#432;&#7899;c ch&#7883;u</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="TR&#431;&#7900;NG PH&#7842;I TR&#7842; &#193;N PH&#205;" target="&#272;I&#7872;U 155 (BO LU&#7852;T H&#204;NH S&#7920; 2015)">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; tr&#432;&#7901;ng h&#7907;p b&#7883; h&#7841;i ph&#7843;i tr&#7843; &#225;n ph&#237;</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I TH&#7920;C HI&#7878;N VI&#7878;C C&#7844;P, GIAO" target="NG&#431;&#7900;I &#272;&#431;&#7906;C NH&#7852;N V&#258;N B&#7842;N T&#7888; T&#7908;NG">
      <data key="d0">Ng&#432;&#7901;i &#273;&#432;&#7907;c nh&#7853;n v&#259;n b&#7843;n t&#7889; t&#7909;ng l&#224; c&#417; quan, t&#7893; ch&#7913;c th&#236; v&#259;n b&#7843;n t&#7889; t&#7909;ng &#273;&#432;&#7907;c giao tr&#7921;c ti&#7871;p cho ng&#432;&#7901;i &#273;&#7841;i di&#7879;n c&#7911;a c&#417; quan, t&#7893; ch&#7913;c &#273;&#243; v&#224; ph&#7843;i &#273;&#432;&#7907;c ng&#432;&#7901;i n&#224;y k&#253; nh&#7853;n</data>
      <data key="d1">1.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I &#272;&#431;&#7906;C NH&#7852;N V&#258;N B&#7842;N T&#7888; T&#7908;NG" target="NG&#431;&#7900;I TH&#7872;M X&#205;CH">
      <data key="d0">Ng&#432;&#7901;i th&#226;n th&#237;ch k&#253; nh&#7853;n v&#224; y&#234;u c&#7847;u ng&#432;&#7901;i n&#224;y cam k&#7871;t giao l&#7841;i ngay cho ng&#432;&#7901;i &#273;&#432;&#7907;c nh&#7853;n</data>
      <data key="d1">6.0</data>
    </edge>
    <edge source="TH&#7910; T&#7908;C TH&#212;NG B&#193;O (&#272;I&#7872;U 141)" target="PH&#431;&#416;NG TI&#7878;N TH&#212;NG TIN &#272;&#7840;I CH&#218;NG">
      <data key="d0">Th&#244;ng b&#225;o tr&#234;n ph&#432;&#417;ng ti&#7879;n th&#244;ng tin &#273;&#7841;i ch&#250;ng &#273;&#432;&#7907;c th&#7921;c hi&#7879;n khi vi&#7879;c ni&#234;m y&#7871;t c&#244;ng khai kh&#244;ng c&#243; k&#7871;t qu&#7843; ho&#7863;c c&#225;c tr&#432;&#7901;ng h&#7907;p kh&#225;c theo quy &#273;&#7883;nh c&#7911;a ph&#225;p lu&#7853;t</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="TH&#7910; T&#7908;C TH&#212;NG B&#193;O (&#272;I&#7872;U 141)" target="C&#7892;NG TH&#212;NG TIN">
      <data key="d0">Th&#244;ng b&#225;o tr&#234;n c&#7893;ng th&#244;ng tin &#273;&#432;&#7907;c &#273;&#259;ng tr&#234;n b&#225;o h&#224;ng ng&#224;y c&#7911;a trung &#432;&#417;ng trong 03 s&#7889; li&#234;n ti&#7871;p v&#224; ph&#225;t s&#243;ng tr&#234;n &#272;&#224;i Ph&#225;t thanh ho&#7863;c &#272;&#224;i Truy&#7873;n h&#236;nh c&#7911;a trung &#432;&#417;ng ba l&#7847;n trong 03 ng&#224;y li&#234;n ti&#7871;p</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="TH&#7910; T&#7908;C TH&#212;NG B&#193;O (&#272;I&#7872;U 141)" target="PH&#7846;N M&#7872;M &#7912;NG D&#7908;NG D&#217;NG CHUNG TRI&#7874;N KHAI T&#7840;I TRUNG T&#194;M D&#7918; LI&#7878;U QU&#7888;C GIA">
      <data key="d0">Ph&#7847;n m&#7873;m &#7913;ng d&#7909;ng d&#249;ng chung tri&#7875;n khai t&#7841;i Trung t&#226;m d&#7919; li&#7879;u qu&#7889;c gia</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="TH&#7910; T&#7908;C TH&#212;NG B&#193;O (&#272;I&#7872;U 141)" target="TRANG TH&#212;NG TIN &#272;I&#7878;N T&#7916; C&#7910;A C&#416; QUAN TI&#7870;N H&#192;NH T&#7888; T&#7908;NG">
      <data key="d0">Th&#244;ng b&#225;o tr&#234;n trang th&#244;ng tin &#273;i&#7879;n t&#7917; c&#7911;a c&#417; quan ti&#7871;n h&#224;nh t&#7889; t&#7909;ng &#273;&#432;&#7907;c th&#7921;c hi&#7879;n khi vi&#7879;c ni&#234;m y&#7871;t c&#244;ng khai kh&#244;ng c&#243; k&#7871;t qu&#7843; ho&#7863;c c&#225;c tr&#432;&#7901;ng h&#7907;p kh&#225;c theo quy &#273;&#7883;nh c&#7911;a ph&#225;p lu&#7853;t</data>
      <data key="d1">9.0</data>
