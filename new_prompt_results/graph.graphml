    <edge source="&#272;i&#7873;u 12 (bo_luat_lao_dong_2019.docx)" target="C&#416; QU&#193;N B&#7842;O HI&#7874;M X&#195; H&#7896;I">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; vi&#7879;c th&#244;ng b&#225;o cho c&#417; quan b&#7843;o hi&#7875;m x&#227; h&#7897;i</data>
      <data key="d1">9.0</data>
