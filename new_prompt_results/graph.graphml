    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="H&#7884;C NGH&#7872;, T&#7852;P NGH&#7896; (&#272;I&#7872;U 61)">
      <data key="d0">Vi&#7879;c tuy&#7875;n d&#7909;ng v&#224; &#273;&#224;o t&#7841;o lao &#273;&#7897;ng theo quy &#273;&#7883;nh c&#7911;a &#272;i&#7873;u 61</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="TH&#7886;A &#7912;C LAO &#272;&#7896;NG T&#7852;P TH&#7874;">
      <data key="d0">Ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng kh&#244;ng &#273;&#432;&#7907;c g&#226;y kh&#243; kh&#259;n, c&#7843;n tr&#7903; ho&#7863;c can thi&#7879;p v&#224;o qu&#225; tr&#236;nh t&#7893; ch&#7913;c &#273;&#7841;i di&#7879;n ng&#432;&#7901;i lao &#273;&#7897;ng l&#7845;y &#253; ki&#7871;n bi&#7875;u quy&#7871;t v&#7873; d&#7921; th&#7843;o th&#7887;a &#432;&#7899;c</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="T&#7892; CH&#7912;C &#272;&#7840;I DI&#7878;N NG&#431;&#7900;I LAO &#272;&#7896;NG">
      <data key="d0">Ph&#7843;i tham kh&#7843;o &#253; ki&#7871;n khi x&#226;y d&#7921;ng thang l&#432;&#417;ng, b&#7843;ng l&#432;&#417;ng v&#224; &#273;&#7883;nh m&#7913;c lao &#273;&#7897;ng</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="THANG L&#431;&#416;NG">
      <data key="d0">Ph&#7843;i c&#244;ng b&#7889; c&#244;ng khai t&#7841;i n&#417;i l&#224;m vi&#7879;c tr&#432;&#7899;c khi th&#7921;c hi&#7879;n</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="B&#7842;NG L&#431;&#416;NG">
      <data key="d0">Ph&#7843;i c&#244;ng b&#7889; c&#244;ng khai t&#7841;i n&#417;i l&#224;m vi&#7879;c tr&#432;&#7899;c khi th&#7921;c hi&#7879;n</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="&#272;&#7882;NH M&#7912;C LAO &#272;&#7896;NG">
      <data key="d0">Ph&#7843;i c&#244;ng b&#7889; c&#244;ng khai t&#7841;i n&#417;i l&#224;m vi&#7879;c tr&#432;&#7899;c khi th&#7921;c hi&#7879;n</data>
