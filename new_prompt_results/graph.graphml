      <data key="d0">Quy &#273;&#7883;nh v&#7873; vi&#7879;c b&#225;o c&#225;o t&#236;nh h&#236;nh thay &#273;&#7893;i v&#7873; lao &#273;&#7897;ng</data>
      <data key="d1">9.0</data>
