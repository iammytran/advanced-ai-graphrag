    <edge source="C&#416; QUAN &#272;I&#7872;U TRA" target="C&#416; QUAN &#272;&#431;&#7906;C GIAO NHI&#7878;M V&#7908; TI&#7870;N H&#192;NH M&#7896;T S&#7888; HO&#7840;T &#272;&#7896;NG &#272;I&#7872;U TRA">
