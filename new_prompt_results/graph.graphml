    <edge source="&#272;I&#7872;U 211 (B&#7896; LU&#7852;T LAO &#272;&#7896;NG 2019)" target="C&#212;NG &#272;O&#192;N C&#217;NG C&#7844;P">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; quy&#7873;n, tr&#225;ch nhi&#7879;m c&#7911;a c&#244;ng &#273;o&#224;n c&#249;ng c&#7845;p</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 211 (B&#7896; LU&#7852;T LAO &#272;&#7896;NG 2019)" target="TR&#431;&#7900;NG H&#7906;P TRANH CH&#7844;P LAO &#272;&#7896;NG">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; gi&#7843;i quy&#7871;t tranh ch&#7845;p lao &#273;&#7897;ng theo quy &#273;&#7883;nh c&#7911;a B&#7897; lu&#7853;t n&#224;y</data>
