      <data key="d0">C&#243; th&#7849;m quy&#7873;n ti&#7871;n h&#224;nh t&#7889; t&#7909;ng thu gi&#7919; ph&#432;&#417;ng ti&#7879;n &#273;i&#7879;n t&#7917;</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="C&#416; QUAN C&#211; TH&#7848;M QUY&#7872;N TI&#7870;N H&#192;NH T&#7888; T&#7908;NG" target="D&#7918; LI&#7878;U &#272;I&#7878;N T&#7916;">
      <data key="d0">C&#243; th&#7849;m quy&#7873;n ti&#7871;n h&#224;nh t&#7889; t&#7909;ng thu gi&#7919; d&#7919; li&#7879;u &#273;i&#7879;n t&#7917;</data>
      <data key="d1">9.0</data>
