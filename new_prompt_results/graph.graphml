      <data key="d0">Ng&#432;&#7901;i kh&#7903;i ki&#7879;n v&#7909; &#225;n d&#226;n s&#7921; c&#243; quy&#7873;n &#273;&#432;&#7907;c b&#7843;o v&#7879; quy&#7873;n l&#7907;i c&#7911;a m&#236;nh</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="NG&#431;&#7900;I B&#7882; &#193;N S&#416; TH&#7874;">
      <data key="d0">Ng&#432;&#7901;i &#273;&#432;&#7907;c T&#242;a &#225;n tuy&#234;n kh&#244;ng c&#243; t&#7897;i c&#243; quy&#7873;n kh&#225;ng c&#225;o v&#7873; c&#225;c c&#259;n c&#7913; m&#224; b&#7843;n &#225;n s&#417; th&#7849;m &#273;&#227; x&#225;c &#273;&#7883;nh l&#224; h&#7885; kh&#244;ng c&#243; t&#7897;i</data>
      <data key="d1">9.0</data>
    </edge>
