    <edge source="C&#416; QUAN C&#211; TH&#7866; QUY&#7872;N TI&#7870;N H&#192;NH T&#7888; T&#7908;NG" target="TH&#7910; T&#7908;C &#272;&#258;NG K&#221; B&#192;O CH&#7918;A">
      <data key="d0">C&#417; quan c&#243; th&#7849;m quy&#7873;n ti&#7871;n h&#224;nh t&#7889; t&#7909;ng ph&#7843;i ki&#7875;m tra gi&#7845;y t&#7901; v&#224; xem x&#233;t vi&#7879;c &#273;&#259;ng k&#253; b&#224;o ch&#7919;a</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="C&#416; QUAN C&#211; TH&#7866; QUY&#7872;N TI&#7870;N H&#192;NH T&#7888; T&#7908;NG" target="TR&#431;&#7900;NG H&#7906;P T&#7914; CH&#7888;I &#272;&#258;NG K&#221; B&#192;O CH&#7918;A">
      <data key="d0">C&#417; quan c&#243; th&#7849;m quy&#7873;n ti&#7871;n h&#224;nh t&#7889; t&#7909;ng t&#7915; ch&#7889;i &#273;&#259;ng k&#253; b&#224;o ch&#7919;a khi thu&#7897;c m&#7897;t trong c&#225;c tr&#432;&#7901;ng h&#7907;p</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="C&#416; QUAN C&#211; TH&#7866; QUY&#7872;N TI&#7870;N H&#192;NH T&#7888; T&#7908;NG" target="V&#258;N B&#7842;N TH&#212;NG B&#193;O NG&#431;&#7900;I B&#192;O CH&#7918;A">
      <data key="d0">V&#259;n b&#7843;n th&#244;ng b&#225;o ng&#432;&#7901;i b&#224;o ch&#7919;a l&#224; c&#243; gi&#225; tr&#7883; s&#7917; d&#7909;ng trong su&#7889;t qu&#225; tr&#236;nh tham gia t&#7889; t&#7909;ng</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I THAM GIA T&#7888; T&#7908;NG" target="T&#210;A &#193;N C&#7844;P PH&#218;C TH&#7910;">
      <data key="d0">Ng&#432;&#7901;i tham gia t&#7889; t&#7909;ng c&#243; quy&#7873;n g&#7917;i v&#259;n b&#7843;n n&#234;u &#253; ki&#7871;n v&#7873; n&#7897;i dung kh&#225;ng c&#225;o, kh&#225;ng ngh&#7883;</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I PH&#7842;I CH&#7910; TH&#7882; THAM GIA T&#7888; T&#7908;NG" target="NG&#431;&#7900;I PHI&#202;N &#272;&#7882;CH, NG&#431;&#7900;I D&#7882;CH THU&#7852;T">
      <data key="d0">&#272;&#432;&#7907;c y&#234;u c&#7847;u tham gia t&#7889; t&#7909;ng</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I PHI&#202;N &#272;&#7882;CH, NG&#431;&#7900;I D&#7882;CH THU&#7852;T" target="NG&#431;&#7900;I C&#211; TH&#7874; THAY &#272;&#7892;I">
      <data key="d0">C&#243; th&#7875; thay &#273;&#7893;i khi thu&#7897;c m&#7897;t trong c&#225;c tr&#432;&#7901;ng h&#7907;p</data>
