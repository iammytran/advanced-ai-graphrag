    <edge source="CH&#7910; T&#7882;CH &#7910;Y BAN NH&#194;N D&#194;N C&#7844;P HUY&#7878;N" target="T&#7882;CH THU QUY&#7872;N S&#7916; D&#7908;NG GI&#7844;Y PH&#201;P, CH&#7912;NG CH&#7880; H&#192;NH NGH&#7872; C&#211; TH&#7900;I H&#7840;N">
      <data key="d0">C&#243; quy&#7873;n t&#432;&#7899;c quy&#7873;n s&#7917; d&#7909;ng gi&#7845;y ph&#233;p, ch&#7913;ng ch&#7881; h&#224;nh ngh&#7873; c&#243; th&#7901;i h&#7841;n</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="CH&#7910; T&#7882;CH &#7910;Y BAN NH&#194;N D&#194;N C&#7844;P HUY&#7878;N" target="&#193;P D&#7908;NG BI&#7878;N PH&#193;P KH&#7854;C PH&#7908;C H&#7852;U QU&#7842;">
      <data key="d0">C&#243; quy&#7873;n &#225;p d&#7909;ng bi&#7879;n ph&#225;p kh&#7855;c ph&#7909;c h&#7853;u qu&#7843;</data>
      <data key="d1">9.0</data>
