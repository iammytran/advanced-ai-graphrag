    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="C&#416; QUAN C&#211; TH&#7848;M QUY&#7872;N TI&#7870;N H&#192;NH T&#7888; T&#7908;NG">
      <data key="d0">&#272;&#432;&#7907;c &#273;&#7873; ngh&#7883; ti&#7871;n h&#224;nh ho&#7841;t &#273;&#7897;ng t&#7889; t&#7909;ng theo quy &#273;&#7883;nh c&#7911;a B&#7897; lu&#7853;t n&#224;y; &#273;&#7873; ngh&#7883; tri&#7879;u t&#7853;p ng&#432;&#7901;i l&#224;m ch&#7913;ng, ng&#432;&#7901;i tham gia t&#7889; t&#7909;ng kh&#225;c, ng&#432;&#7901;i c&#243; th&#7849;m quy&#7873;n ti&#7871;n h&#224;nh t&#7889; t&#7909;ng</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="BI&#202;N B&#7842;N V&#7872; HO&#7840;T &#272;&#7896;NG T&#7888; T&#7908;NG">
      <data key="d0">C&#243; quy&#7873;n xem</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="CH&#7910; T&#7912;C V&#7908;">
      <data key="d0">Kh&#244;ng &#273;&#432;&#7907;c ti&#7871;t l&#7897; th&#244;ng tin v&#7873; v&#7909; &#225;n, v&#7873; ng&#432;&#7901;i b&#7883; bu&#7897;c t&#7897;i m&#224; m&#236;nh bi&#7871;t khi b&#224;o ch&#7919;a, tr&#7915; tr&#432;&#7901;ng h&#7907;p ng&#432;&#7901;i n&#224;y &#273;&#7891;ng &#253; b&#7857;ng v&#259;n b&#7843;n v&#224; kh&#244;ng &#273;&#432;&#7907;c s&#7917; d&#7909;ng th&#244;ng tin &#273;&#243; v&#224;o m&#7909;c &#273;&#237;ch x&#226;m ph&#7841;m l&#7907;i &#237;ch c&#7911;a Nh&#224; n&#432;&#7899;c, l&#7907;i &#237;ch c&#244;ng c&#7897;ng, quy&#7873;n v&#224; l&#7907;i &#237;ch h&#7907;p ph&#225;p c&#7911;a c&#417; quan, t&#7893; ch&#7913;c, c&#225; nh&#226;n</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="TH&#7910; T&#7908;C &#272;&#258;NG K&#221; B&#192;O CH&#7918;A">
      <data key="d0">Th&#7911; t&#7909;c &#273;&#259;ng k&#253; b&#224;o ch&#7919;a l&#224; b&#7855;t bu&#7897;c</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="GI&#7844;Y T&#7900;">
      <data key="d0">Gi&#7845;y t&#7901; c&#7847;n xu&#7845;t tr&#236;nh khi &#273;&#259;ng k&#253; b&#224;o ch&#7919;a l&#224; b&#7855;t bu&#7897;c</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="CH&#7910; C&#416; QUY&#7872;N THI&#7870;N H&#192;NH T&#7892; T&#7908;NG">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; giao ch&#7913;ng c&#7913;, t&#224;i li&#7879;u, &#273;&#7891; v&#7853;t li&#234;n quan &#273;&#7871;n vi&#7879;c b&#224;o ch&#7919;a</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="BI&#202;N B&#7842;N TH&#7874; H&#192;NH">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; l&#7853;p bi&#234;n b&#7843;n giao, nh&#7853;n ch&#7913;ng c&#7913;, t&#224;i li&#7879;u, &#273;&#7891; v&#7853;t</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="TR&#431;&#7900;NG H&#7906;P KH&#212;NG TH&#7874; THU TH&#7852;P">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; &#273;&#7873; ngh&#7883; c&#417; quan c&#243; th&#7849;m quy&#7873;n thu th&#7853;p</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="C&#416; QUAN C&#211; TH&#7848;M QUY&#7872;N THI&#7870;N H&#192;NH T&#7892; T&#7908;NG">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; thu th&#7853;p ch&#7913;ng c&#7913;, t&#224;i li&#7879;u, &#273;&#7891; v&#7853;t li&#234;n quan &#273;&#7871;n vi&#7879;c b&#224;o ch&#7919;a</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I B&#192;O CH&#7918;A" target="C&#416; QUAN &#272;I&#7872;U TRA">
      <data key="d0">Ph&#7843;i g&#7917;i b&#7843;n k&#7871;t lu&#7853;n &#273;i&#7873;u tra &#273;&#7873; ngh&#7883; truy t&#7889; ho&#7863;c quy&#7871;t &#273;&#7883;nh &#273;&#236;nh ch&#7881; &#273;i&#7873;u tra</data>
      <data key="d1">9.0</data>
    </edge>
