    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="PH&#7840;T TI&#7872;N T&#7914; 15 NG&#192;Y &#272;&#7870;N 30 NG&#192;Y">
      <data key="d0">Ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng ph&#7843;i &#273;&#7873;n b&#249; cho ng&#432;&#7901;i lao &#273;&#7897;ng m&#7897;t kho&#7843;n ti&#7873;n &#237;t nh&#7845;t b&#7857;ng s&#7889; ti&#7873;n l&#227;i c&#7911;a s&#7889; ti&#7873;n tr&#7843; ch&#7853;m</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="TH&#7900;I H&#7840;N TR&#7842; L&#431;&#416;NG">
      <data key="d0">Ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng ph&#7843;i tr&#7843; l&#432;&#417;ng &#273;&#250;ng h&#7841;n trong tr&#432;&#7901;ng h&#7907;p b&#7845;t kh&#7843; kh&#225;ng</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="TH&#7900;I GI&#7900; L&#192;M VI&#7878;C B&#204;NH TH&#431;&#7900;NG">
      <data key="d0">C&#243; quy&#7873;n quy &#273;&#7883;nh th&#7901;i gi&#7901; l&#224;m vi&#7879;c</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="&#272;I&#7872;U 107 (LU&#7852;T X)">
      <data key="d0">C&#243; tr&#225;ch nhi&#7879;m th&#244;ng b&#225;o cho c&#417; quan chuy&#234;n m&#244;n v&#7873; lao &#273;&#7897;ng thu&#7897;c &#7910;y ban nh&#226;n d&#226;n c&#7845;p t&#7881;nh</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="&#272;I&#7872;U 118 (LU&#7852;T X)">
      <data key="d0">Ph&#7843;i tham kh&#7843;o &#253; ki&#7871;n c&#7911;a t&#7893; ch&#7913;c &#273;&#7841;i di&#7879;n ng&#432;&#7901;i lao &#273;&#7897;ng t&#7841;i c&#417; s&#7903;</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="&#272;I&#7872;U 122 (BO LU&#7852;T LAO &#272;&#7896;NG 2019)">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng ph&#7843;i ch&#7913;ng minh &#273;&#432;&#7907;c l&#7895;i c&#7911;a ng&#432;&#7901;i lao &#273;&#7897;ng</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="&#272;I&#7872;U 144 (B&#7896; LU&#7852;T H&#204;NH S&#7920; 2015)">
      <data key="d0">Ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng c&#243; tr&#225;ch nhi&#7879;m quan t&#226;m ch&#259;m s&#243;c lao &#273;&#7897;ng ch&#432;a th&#224;nh ni&#234;n</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="L&#195;O &#272;&#7896;NG CH&#431;A TH&#192;NH NI&#202;N">
      <data key="d0">Ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng ph&#7843;i t&#7841;o c&#417; h&#7897;i &#273;&#7875; lao &#273;&#7897;ng ch&#432;a th&#224;nh ni&#234;n &#273;&#432;&#7907;c h&#7885;c v&#259;n h&#243;a, gi&#225;o d&#7909;c ngh&#7873; nghi&#7879;p, &#273;&#224;o t&#7841;o, b&#7891;i d&#432;&#7905;ng, n&#226;ng cao tr&#236;nh &#273;&#7897; k&#7929; n&#259;ng ngh&#7873;</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="&#272;I&#7872;U 149 (BO LU&#7852;T L&#195;O &#272;&#7896;NG 2019)">
      <data key="d0">Ng&#432;&#7901;i lao &#273;&#7897;ng cao tu&#7893;i &#273;&#432;&#7907;c s&#7917; d&#7909;ng theo quy &#273;&#7883;nh t&#7841;i &#272;i&#7873;u 149</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="&#272;I&#7872;U 168 (B&#7896; LU&#7852;T H&#204;NH S&#7920; 2015)">
      <data key="d0">C&#243; tr&#225;ch nhi&#7879;m tham gia b&#7843;o hi&#7875;m x&#227; h&#7897;i, b&#7843;o hi&#7875;m y t&#7871;, b&#7843;o hi&#7875;m th&#7845;t nghi&#7879;p</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="&#272;I&#7872;U 202 (B&#7896; LU&#7852;T LAO &#272;&#7896;NG 2019)">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; ngh&#297;a v&#7909; c&#7911;a ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng khi ng&#432;&#7901;i lao &#273;&#7897;ng t&#7893; ch&#7913;c v&#224; l&#227;nh &#273;&#7841;o &#273;&#236;nh c&#244;ng</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="T&#7892; CH&#7912;C &#272;&#7840;I DI&#7878;N NG&#431;&#7900;I LAO &#272;&#7896;NG T&#7840;I C&#416; S&#7902;" target="&#272;I&#7872;U 122 (BO LU&#7852;T LAO &#272;&#7896;NG 2019)">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; t&#7893; ch&#7913;c &#273;&#7841;i di&#7879;n ng&#432;&#7901;i lao &#273;&#7897;ng t&#7841;i c&#417; s&#7903; ph&#7843;i tham gia x&#7917; l&#253; k&#7927; lu&#7853;t lao &#273;&#7897;ng</data>
      <data key="d1">9.0</data>
    </edge>
    <edge source="T&#7892; CH&#7912;C &#272;&#7840;I DI&#7878;N NG&#431;&#7900;I S&#7916; D&#7908;NG LAO &#272;&#7896;NG" target="QUAN H&#202;&#803; LAO &#272;&#7896;NG">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; quan h&#7879; lao &#273;&#7897;ng l&#224; &#273;&#7889;i t&#432;&#7907;ng &#273;&#432;&#7907;c quy &#273;&#7883;nh trong quy &#273;&#7883;nh v&#7873; t&#7893; ch&#7913;c &#273;&#7841;i di&#7879;n ng&#432;&#7901;i s&#7917; d&#7909;ng lao &#273;&#7897;ng</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="QUAN H&#202;&#803; LAO &#272;&#7896;NG" target="NG&#431;&#7900;I L&#192;M VI&#7878;C KH&#212;NG C&#211; QUAN H&#202;&#803; LAO &#272;&#7896;NG">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; quan h&#7879; lao &#273;&#7897;ng l&#224; &#273;&#7889;i t&#432;&#7907;ng &#273;&#432;&#7907;c quy &#273;&#7883;nh trong quy &#273;&#7883;nh v&#7873; ng&#432;&#7901;i lao &#273;&#7897;ng</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="C&#431;&#7904;NG B&#7896;C LAO &#272;&#7896;NG" target="PH&#194;N BI&#7878;T &#272;&#7888;I T&#7912; NG&#192;NH LAO &#272;&#7896;NG">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; ph&#226;n bi&#7879;t &#273;&#7889;i x&#7917; trong lao &#273;&#7897;ng l&#224; h&#7853;u qu&#7843; c&#7911;a vi&#7879;c c&#432;&#7905;ng b&#7913;c lao &#273;&#7897;ng</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="PH&#194;N BI&#7878;T &#272;&#7888;I T&#7912; NG&#192;NH LAO &#272;&#7896;NG" target="QU&#7844;Y R&#7888;I T&#204;NH D&#7882;U T&#7840;I N&#416;I L&#192;M VI&#7878;C">
      <data key="d0">Quy &#273;&#7883;nh v&#7873; qu&#7845;y r&#7889;i t&#236;nh d&#7909;c t&#7841;i n&#417;i l&#224;m vi&#7879;c l&#224; h&#224;nh vi ph&#226;n bi&#7879;t &#273;&#7889;i x&#7917; trong lao &#273;&#7897;ng</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 6 (BO LU&#7852;T H&#204;NH S&#7920; 2015)" target="C&#416; QUAN C&#211; TH&#7866;M QUY&#7872;N TI&#7870;N H&#192;NH T&#7888; T&#7908;NG">
      <data key="d0">Ph&#7843;i ph&#225;t hi&#7879;n nguy&#234;n nh&#226;n v&#224; &#273;i&#7873;u ki&#7879;n ph&#7841;m t&#7897;i</data>
      <data key="d1">8.0</data>
    </edge>
    <edge source="&#272;I&#7872;U 6 (BO LU&#7852;T H&#204;NH S&#7920; 2015)" target="C&#416; QUAN, T&#7892; CH&#7912;C H&#7918;U QUAN">
      <data key="d0">Ph&#7843;i tr&#7843; l&#7901;i y&#234;u c&#7847;u, ki&#7871;n ngh&#7883; c&#7911;a c&#417; quan c&#243; th&#7849;m quy&#7873;n ti&#7871;n h&#224;nh t&#7889; t&#7909;ng trong th&#7901;i h&#7841;n 15 ng&#224;y</data>
      <data key="d1">9.0</data>
    </edge>
